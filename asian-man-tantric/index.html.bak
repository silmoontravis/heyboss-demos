            <form class="booking-form reveal" id="bookingForm" novalidate>
                <div class="form-row">
                    <div class="form-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" placeholder="Your name" required>
                        <span class="form-error">Please enter your name</span>
                    </div>
                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" placeholder="your@email.com" required>
                        <span class="form-error">Please enter a valid email</span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="phone">Phone Number</label>
                        <input type="tel" id="phone" name="phone" placeholder="+44 ..." required>
                        <span class="form-error">Please enter your phone number</span>
                    </div>
                    <div class="form-group">
                        <label for="service">Service</label>
                        <select id="service" name="service" required>
                            <option value="" disabled selected>Select a service</option>
                            <option value="deep-tissue">Deep Tissue / Swedish Massage &mdash; from &pound;150</option>
                            <option value="body-to-body">Tantric Body-to-Body Massage &mdash; from &pound;200</option>
                            <option value="ultimate">Full Ultimate Tantric Journey &mdash; from &pound;300</option>
                        </select>
                        <span class="form-error">Please select a service</span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="date">Preferred Date</label>
                        <input type="date" id="date" name="date" required>
                        <span class="form-error">Please select a date</span>
                    </div>
                    <div class="form-group">
                        <label for="time">Preferred Time</label>
                        <select id="time" name="time" required>
                            <option value="" disabled selected>Select a time</option>
                            <option value="10:00">10:00</option>
                            <option value="11:00">11:00</option>
                            <option value="12:00">12:00</option>
                            <option value="13:00">13:00</option>
                            <option value="14:00">14:00</option>
                            <option value="15:00">15:00</option>
                            <option value="16:00">16:00</option>
                            <option value="17:00">17:00</option>
                            <option value="18:00">18:00</option>
                            <option value="19:00">19:00</option>
                            <option value="20:00">20:00</option>
                            <option value="21:00">21:00</option>
                        </select>
                        <span class="form-error">Please select a time</span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group full">
                        <label for="message">Message <span style="color: var(--gray-text); text-transform: none; letter-spacing: 0;">(optional)</span></label>
                        <textarea id="message" name="message" placeholder="Any special requests or questions..."></textarea>
                    </div>
                </div>
                <button type="submit" class="form-submit">Book My Session</button>
                <p class="form-note">We respond within 2 hours &mdash; Your privacy is guaranteed</p>
            </form>
            <div class="form-success" id="formSuccess">
                <h3>Thank You</h3>
                <p>Your booking request has been received. We will get back to you within 2 hours.</p>
            </div>
        </div>
    </section>

