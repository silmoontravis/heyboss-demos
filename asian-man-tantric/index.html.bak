                    <div class="service-card-image">
                        <img src="data:image/jpeg;base64," alt="Full Ultimate Tantric Journey" loading="lazy">
                    </div>
                    <div class="service-card-body">
                        <h3>Full Ultimate Tantric Journey</h3>
                        <p>Our signature experience &mdash; a complete immersion combining breathwork, energy alignment, and the full spectrum of tantric techniques for total mind-body transformation.</p>
                        <span class="service-price">From &pound;300 <span>/ session</span></span>
                        <a href="#booking" class="service-btn">Book Now</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

